# Backend API base URL — get from CloudFormation outputs after deploy
# Run: aws cloudformation describe-stacks --stack-name PocSemanticSearchStackV2 \
#        --profile harrison-cicd --region us-east-1 \
#        --query 'Stacks[0].Outputs[?OutputKey==`ServingFunctionUrl`].OutputValue' --output text
# Format: https://<id>.lambda-url.<region>.on.aws/
VITE_API_BASE_URL=https://YOUR-FUNCTION-URL-HERE.lambda-url.us-east-1.on.aws

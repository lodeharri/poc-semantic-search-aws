{
  "name": "poc-semantic-search-monorepo",
  "private": true,
  "version": "0.0.1",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "build": "pnpm -r build",
    "backend:install": "cd backend && pnpm install",
    "backend:dev": "cd backend && pnpm dev",
    "backend:deploy": "cd backend && pnpm cdk:deploy",
    "frontend:install": "cd frontend && pnpm install",
    "frontend:dev": "cd frontend && pnpm dev",
    "frontend:build": "cd frontend && pnpm build",
    "bootstrap:aws": "bash scripts/bootstrap-aws.sh",
    "bootstrap:github": "bash scripts/bootstrap-github.sh",
    "bootstrap:all": "pnpm bootstrap:aws && pnpm bootstrap:github"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
